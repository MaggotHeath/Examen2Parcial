# URL de conexión a Postgres (Neon / Vercel Postgres)
# Usa la connection string "pooled" que te da Neon/Vercel
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require"

# Secreto para firmar los JWT (cámbialo por uno propio y largo)
JWT_SECRET="reemplaza-esto-por-un-secreto-largo-y-aleatorio"

# URL del frontend en Vercel, para configurar CORS correctamente en producción
FRONTEND_URL="https://tu-frontend.vercel.app"

# Puerto local (opcional, Vercel lo ignora en producción)
PORT=3000
